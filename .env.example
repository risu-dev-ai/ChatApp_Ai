# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# ==============================================================================
# HIGH-SCALE ARCHITECTURE CONFIGURATION (For 1 Million+ Concurrent Users)
# ==============================================================================

# MongoDB Connection for persistent global message threads and profiles
MONGODB_URI="mongodb+srv://admin:secure_password@cluster0.bakbak.mongodb.net/bakbak?retryWrites=true&w=majority"

# Redis Cache connection for sub-millisecond chat delivery & session replication
REDIS_URI="redis://:strong_redis_password@redis-cache.bakbak.net:6379"

# Cloudinary CDN Configuration for media image, audio & video storage
CLOUDINARY_CLOUD_NAME="bakbak-chat-media"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Auto Media Compression (Options: high, medium, raw)
# Compresses images, audios, and videos on-the-fly before storing in CDN
MEDIA_COMPRESSION_LEVEL="high"

# ==============================================================================
# OTP VERIFICATION & DELIVERY CONFIGURATION (WhatsApp, Telegram, Email)
# ==============================================================================
# Telegram Bot Token & Chat ID for free, instant mobile number OTP alerts
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Nodemailer SMTP Configuration for real email verification
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
